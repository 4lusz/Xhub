# Backend
# Cobre backend/.env e qualquer variante de nome que termine em .env
# (ex.: "backend/ - Copia.env"), que antes NAO era coberta pelo match
# exato "backend/.env" -- auditoria item 10: um arquivo assim, com um
# segredo real de producao (X_CLIENT_SECRET), acabou sendo entregue
# fora da protecao do .gitignore. Qualquer arquivo terminado em .env
# dentro de backend/ agora e ignorado; use backend/.env.example (sem
# segredos reais) como referencia versionada.
backend/*.env
backend/**/*.env
backend/__pycache__/
backend/**/__pycache__/
backend/*.egg-info/
backend/.venv/
backend/venv/
*.pyc

# Arquivos de midia enviados pelos usuarios (ver app.core.media_storage) --
# nunca versionar conteudo de upload.
backend/media_storage/

# Frontend
frontend/node_modules/
frontend/dist/
frontend/*.env

# ffmpeg-core.js/.wasm regenerados a cada `npm install` (postinstall,
# ver scripts/copy-ffmpeg-core.mjs) -- nunca versionar o binario (~32MB).
frontend/public/ffmpeg/

# Geral
.DS_Store
*.log
.idea/
.vscode/
