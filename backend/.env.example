# Geral
# ENVIRONMENT=development permite valores padrao/fracos de JWT_SECRET_KEY
# e TOKEN_ENCRYPTION_KEY (apenas para rodar localmente sem configuracao
# extra). Qualquer outro valor (ex.: "production", "staging") ativa a
# validacao estrita em app/config/settings.py: a aplicacao recusa subir
# se JWT_SECRET_KEY ou TOKEN_ENCRYPTION_KEY estiverem ausentes, vazios,
# ou iguais a algum valor de exemplo deste arquivo.
ENVIRONMENT=development
DEBUG=false

# Banco de dados (deve bater com o docker-compose.yml)
DATABASE_URL=postgresql+psycopg://xhub:xhub@db:5432/xhub

# JWT
# Em producao: gerar com `python -c "import secrets; print(secrets.token_urlsafe(48))"`
# Minimo de 32 caracteres. NUNCA usar o valor de exemplo abaixo fora do
# ambiente de desenvolvimento.
JWT_SECRET_KEY=troque-esta-chave-em-producao
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Chave de criptografia (Fernet) usada para cifrar em repouso os tokens
# OAuth do X (access_token/refresh_token) antes de gravar no banco.
# Em producao: gerar com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# NUNCA usar o valor de exemplo abaixo fora do ambiente de desenvolvimento.
TOKEN_ENCRYPTION_KEY=troque-esta-chave-em-producao

# OAuth2 do X (Twitter)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_CALLBACK_URL=http://localhost:8000/api/v1/oauth/x/callback
# media.write permite upload de imagem/gif/video em nome do usuario.
# Contas conectadas antes desta variavel incluir media.write precisam
# ser reconectadas para poder publicar posts com midia.
X_OAUTH_SCOPES=tweet.read tweet.write users.read offline.access media.write
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Compatibilidade com nomes antigos usados nas etapas iniciais.
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_REDIRECT_URI=http://localhost:8000/api/v1/oauth/twitter/callback

# CORS
CORS_ORIGINS=["http://localhost:5173"]


# Rate limiting de /auth/login
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_MAX_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
# So habilite se a aplicacao roda atras de um proxy/load balancer
# confiavel que sobrescreve o header X-Forwarded-For.
TRUST_PROXY_HEADERS=false

# Agendamento de posts (worker in-process via APScheduler)
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_SECONDS=30
SCHEDULER_BATCH_SIZE=25

# Publicacao Inteligente -- integracao com a Groq para geracao de
# variacoes naturais de texto (ver
# docs/ROADMAP_PUBLICACAO_INTELIGENTE.md). O roadmap oficial exige o
# uso da Groq; NAO utilizar OpenAI para esta funcionalidade.
# Obtenha a chave em https://console.groq.com/keys -- nao commitar o
# valor real, apenas usar esta variavel no seu .env local/producao.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=15
AI_CONTENT_VARIATION_PROMPT_VERSION=v1
INTELLIGENT_PUBLICATION_CACHE_ENABLED=true
INTELLIGENT_PUBLICATION_CACHE_TTL_SECONDS=600

# Midia (imagem/gif/video) anexada a posts (ver docs/ROADMAP_MEDIA.md).
# MEDIA_STORAGE_DIR e relativo ao working directory do backend (/app no
# container, que e o bind mount ./backend do host) -- os arquivos ficam
# em backend/media_storage/ no host, sem exigir volume Docker extra.
MEDIA_STORAGE_DIR=media_storage
X_MEDIA_UPLOAD_CHUNK_SIZE_BYTES=4194304
X_MEDIA_UPLOAD_TIMEOUT_SECONDS=30
X_MEDIA_STATUS_MAX_WAIT_SECONDS=90
